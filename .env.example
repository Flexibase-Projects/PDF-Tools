# Copie para .env.local e preencha com seus valores.
# O .env.local não é versionado (está no .gitignore).

# Supabase (frontend - Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (backend/serviços, se usar)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ollama (LLM local, se usar)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# URL do frontend (ex.: para callbacks/CORS)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:8080
